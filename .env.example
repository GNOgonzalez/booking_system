# Copy to .env and fill in. Never commit .env.

# --- Core ---
SECRET_KEY=change-me-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# --- Database (PostgreSQL) ---
DB_NAME=booking_dev
DB_USER=booking_user
DB_PASSWORD=devpassword123
DB_HOST=127.0.0.1
DB_PORT=5432

# --- Frontend / CORS ---
CORS_ALLOWED_ORIGINS=http://127.0.0.1:5173,http://localhost:5173
CSRF_TRUSTED_ORIGINS=

# --- Email (leave EMAIL_HOST blank to print emails to console) ---
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=no-reply@booking.local

# --- Stripe (optional; blank = mock payments) ---
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=

# --- Google (optional; blank = placeholder Meet links) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- SimplyBook (optional; blank = adapter inert) ---
SIMPLYBOOK_API_KEY=
SIMPLYBOOK_COMPANY=

# --- Production only ---
SECURE_SSL_REDIRECT=True
SECURE_HSTS_SECONDS=3600
